ROSIE_USUARIO=seu.usuario
ROSIE_SENHA=sua_senha

# Janela de apontamento liberada no ROSIE (formato YYYY-MM-DD)
# Se --dias não for informado, os dias são gerados automaticamente entre início e fim
JANELA_INICIO=2026-06-01
JANELA_FIM=2026-06-05

# Feriados em que a automação não lança (separados por vírgula)
FERIADOS_EXCLUIDOS=2026-06-04

# Conteúdo do apontamento
HORA_ENTRADA=08:00
HORA_SAIDA=17:00
ALMOCO_INICIO=12:00
ALMOCO_DURACAO_MIN=60
CLIENTE=UNIMED CAMPINAS COOPERATIVA
PROJETO=[BS] JONATHAN DA SILVA
EDT=ALOCAÇÃO DE HORAS
ATIVIDADE=BODY SHOP
OBSERVACAO=Apontamento automático - ROSIE

# Limite mensal de horas (padrão: 184)
LIMITE_HORAS=184

# Máximo de horas de trabalho por dia (padrão: 8)
HORAS_DIA_MAX=8
